// Demo Modal Functions
function openDemoModal() {
  const modal = document.getElementById('demoModal');
  if (modal) {
    modal.style.display = 'flex';
    document.body.style.overflow = 'hidden'; // Prevent background scrolling
  }
}

function closeDemoModal() {
  const modal = document.getElementById('demoModal');
  if (modal) {
    modal.style.display = 'none';
    document.body.style.overflow = ''; // Restore scrolling
  }
}

// Close modal on Escape key
document.addEventListener('keydown', function(event) {
  if (event.key === 'Escape') {
    closeDemoModal();
  }
});

// Login Dropdown Functions
function toggleLoginDropdown() {
  const loginWrappers = document.querySelectorAll('.login-button-wrapper');
  // Close products dropdown if open
  const productsWrapper = document.querySelector('.products-dropdown-wrapper');
  if (productsWrapper) productsWrapper.classList.remove('active');
  
  loginWrappers.forEach(wrapper => {
    wrapper.classList.toggle('active');
  });
}

function toggleProductsDropdown() {
  const productsWrapper = document.querySelector('.products-dropdown-wrapper');
  // Close login dropdowns if open
  const loginWrappers = document.querySelectorAll('.login-button-wrapper');
  loginWrappers.forEach(wrapper => wrapper.classList.remove('active'));
  
  if (productsWrapper) {
    productsWrapper.classList.toggle('active');
  }
}

// Close dropdown when clicking outside
document.addEventListener('click', function(event) {
  const loginWrappers = document.querySelectorAll('.login-button-wrapper');
  const productsWrapper = document.querySelector('.products-dropdown-wrapper');
  
  const clickedInsideLogin = Array.from(loginWrappers).some(wrapper => wrapper.contains(event.target));
  const clickedInsideProducts = productsWrapper && productsWrapper.contains(event.target);
  
  if (!clickedInsideLogin) {
    loginWrappers.forEach(wrapper => {
      wrapper.classList.remove('active');
    });
  }
  
  if (!clickedInsideProducts && productsWrapper) {
    productsWrapper.classList.remove('active');
  }
});
</script>
